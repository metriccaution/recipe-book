---
import Base from '../layouts/Base.astro';
import { Content as Blurb } from '../content/blurb.md';

import { recipes, allSections } from '../data.ts';
import { siteUrl } from '../utils.ts';

const sections = allSections();
---

<Base title="Recipes">
  <h1>Recipes</h1>
  <Blurb />

  <h2>Browse by section</h2>
  <ul class="section-list">
    {sections.map((section) => {
      const count = recipes.filter((r) => r.section === section).length;
      return (
        <li>
          <a href={siteUrl(`/section/${section.toLowerCase()}/`)}>{section}</a>
          <span class="count">{count}</span>
        </li>
      );
    })}
  </ul>

  <link slot="head" rel="stylesheet" href={siteUrl('/pagefind/pagefind-ui.css')} />
  <div id="search" class="home-search"></div>

</Base>

<script define:vars={{ base: import.meta.env.BASE_URL }}>
  const basePath = base.replace(/\/$/, '');
  import(basePath + '/pagefind/pagefind-ui.js').then(() => {
    new window.PagefindUI({ element: '#search', showSubResults: false, showImages: false, bundlePath: basePath + '/pagefind/' });
  });
</script>

<style>
  .section-list {
    list-style: none;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(160px, 1fr));
    gap: 0.5rem;
    margin-bottom: 0.75rem;
  }
  .section-list li {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 0.5rem 0.6rem;
    background: #f8f8f8;
    border-radius: 4px;
    font-size: 0.95rem;
  }
  .section-list a { text-decoration: none; font-weight: 500; }
  .section-list a:hover { text-decoration: underline; }
  .count { font-size: 0.8rem; color: var(--color-muted); }
  .home-search { margin: 1.25rem 0; }
</style>
