---
import Base from '../layouts/Base.astro';
import { siteUrl } from '../utils.ts';
---

<Base title="Search — Recipes">
  <link slot="head" rel="stylesheet" href={siteUrl('/pagefind/pagefind-ui.css')} />
  <h1>Search</h1>
  <div id="search"></div>
</Base>

<script define:vars={{ base: import.meta.env.BASE_URL }}>
  const basePath = base.replace(/\/$/, '');
  import(basePath + '/pagefind/pagefind-ui.js').then(() => {
    new window.PagefindUI({ element: '#search', showSubResults: false, bundlePath: basePath + '/pagefind/' });
  });
</script>

<style>
  #search { margin-top: 1rem; }
</style>
