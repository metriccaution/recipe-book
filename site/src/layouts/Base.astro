---
import { siteUrl } from '../utils.ts';

interface Props {
  title: string;
  description?: string;
  jsonLd?: string;
}

const { title, description, jsonLd } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    {description && <meta name="description" content={description} />}
    {jsonLd && <script type="application/ld+json" set:html={jsonLd} />}
    <slot name="head" />
    <style>
      :root {
        --color-bg: #fff;
        --color-text: #1a1a1a;
        --color-muted: #555;
        --color-border: #ddd;
        --color-accent: #2a6496;
        --max-width: 780px;
        --font: system-ui, -apple-system, sans-serif;
      }
      *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
      body {
        font-family: var(--font);
        font-size: 1rem;
        line-height: 1.6;
        color: var(--color-text);
        background: var(--color-bg);
      }
      a { color: var(--color-accent); }
      a:hover { text-decoration: none; }
      header {
        max-width: var(--max-width);
        margin: 0 auto;
        padding: 1.25rem 1rem 1rem;
        border-bottom: 1px solid var(--color-border);
        display: flex;
        align-items: baseline;
        gap: 1.5rem;
      }
      header .site-name {
        font-weight: 700;
        font-size: 1.1rem;
        text-decoration: none;
        color: var(--color-text);
      }
      header nav { display: flex; gap: 1rem; font-size: 0.9rem; }
      main {
        max-width: var(--max-width);
        margin: 2rem auto 4rem;
        padding: 0 1rem;
      }
      footer {
        max-width: var(--max-width);
        margin: 0 auto;
        padding: 1.5rem 1rem;
        border-top: 1px solid var(--color-border);
        font-size: 0.85rem;
        color: var(--color-muted);
      }
      h1 { font-size: 1.75rem; line-height: 1.3; margin-bottom: 0.5rem; }
      h2 { font-size: 1.2rem; margin: 1.75rem 0 0.6rem; }
      p { margin-bottom: 0.75rem; }
      ul { padding-left: 1.25rem; margin-bottom: 0.75rem; }
      li { margin-bottom: 0.25rem; }
    </style>
  </head>
  <body>
    <header data-pagefind-ignore>
      <a class="site-name" href={siteUrl('/')}>Recipes</a>
      <nav>
        <a href={siteUrl('/tag/')}>Tags</a>
        <a href={siteUrl('/search/')}>Search</a>
      </nav>
    </header>
    <main>
      <slot />
    </main>
    <footer data-pagefind-ignore>
      <a href={siteUrl('/cookbook.pdf')}>Cookbook</a>
      <a href={siteUrl('/repo.json')}>Raw Data</a> ·
    </footer>
  </body>
</html>
